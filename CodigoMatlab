% Nodos
function [rx, ry] = generar_puntos_zigzag(L, step)
    rx = []; ry = [];
    y = 0;
    while y <= L
        rx = [rx 0 L];
        ry = [ry y y];
        y = y + step;
        if y <= L
            rx = [rx L 0];
            ry = [ry y y];
            y = y + step;
        end
    end
end
