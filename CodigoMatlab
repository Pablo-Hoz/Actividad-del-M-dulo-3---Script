  %      break
 %   end
%end

% Error GPS

MSE_x = mean(error_x.^2);
MSE_y = mean(error_y.^2);
MSE_total = mean(error_x.^2 + error_y.^2);

disp('==== MÉTRICAS DE ERROR ====')
disp(['MSE X = ' num2str(MSE_x)])
disp(['MSE Y = ' num2str(MSE_y)])
disp(['MSE TOTAL = ' num2str(MSE_total)])

